# Archivo de configuración de entorno (.env) para desarrollo local
# Este archivo NO DEBE SUBIRSE AL REPOSITORIO.

# --- Configuración del Bot Engine ---
PORT=5001
VERIFY_TOKEN=LOCAL_VERIFY_TOKEN
META_APP_ID=LOCAL_META_APP_ID
META_APP_SECRET=LOCAL_META_APP_SECRET
WHATSAPP_TOKEN=LOCAL_WHATSAPP_TOKEN
WHATSAPP_PHONE_ID=LOCAL_WHATSAPP_PHONE_ID
INSTAGRAM_TOKEN=LOCAL_INSTAGRAM_TOKEN
NGROK_URL=http://localhost:5001 # Para pruebas de webhook si se activa ngrok

# --- Configuración de la Base de Datos ---
DATABASE_URL=sqlite:///./bot-manager/database/bot_dashboard.db # Ruta relativa al engine

# --- Configuración del Admin Panel Backend (Credenciales de Login) ---
ADMIN_USER=admin
ADMIN_PASS=idear2024
